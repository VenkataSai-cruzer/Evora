# ──────────────────────────────────────────────
# Jamming Events — Environment Configuration
# ──────────────────────────────────────────────
#
# Database — PostgreSQL only.
# Development: Use a local or Supabase PostgreSQL instance.
# Test: Use a separate PostgreSQL test database.
# Production: Use a managed PostgreSQL instance (RDS, Cloud SQL, Supabase, etc.).
# Never use SQLite in development, test, or production.

# Database (Development)
DATABASE_URL=postgresql://user:password@localhost:5432/jamming

# Database (Test) — Separate from development database
# DATABASE_URL_TEST=postgresql://user:password@localhost:5432/jamming_test

# Application URL — Must be publicly accessible for OAuth callbacks.
NEXTAUTH_URL=http://localhost:3000

# Authentication Secret — Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-secret

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# QR Security — Generate with: openssl rand -hex 32
QR_SECRET_KEY=change-me-to-a-random-hex-key

# Application URL (for QR verification, pass generation, etc.)
APP_URL=http://localhost:3000

# Upload Storage (Phase 2 — Persistent Storage)
# Provider options: local, s3, r2, supabase
UPLOAD_STORAGE_PROVIDER=local
# UPLOAD_STORAGE_BUCKET=
# UPLOAD_STORAGE_ACCESS_KEY=
# UPLOAD_STORAGE_SECRET_KEY=
# UPLOAD_STORAGE_ENDPOINT=
# UPLOAD_STORAGE_REGION=

# Logging
LOG_LEVEL=debug

# (Phase 2) Stripe Payment Integration
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# (Phase 2) Blockchain Integration
# ETH_RPC_URL=
# ETH_PRIVATE_KEY=
# TICKET_CONTRACT_ADDRESS=
# BLOCKCHAIN_SECRET=

# (Phase 2) Email Service
# RESEND_API_KEY=

# (Phase 2) Rate Limiting (Redis/Upstash)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
