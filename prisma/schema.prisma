generator client {
  provider = "prisma-client-js"
}

// ═══════════════════════════════════════════════════════════════════
// Development: SQLite (config in .env)
// Production:  PostgreSQL on Supabase
// ═══════════════════════════════════════════════════════════════════
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────
// USER & AUTH
// ───────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  passwordHash    String?
  role            String    @default("ATTENDEE") // ATTENDEE | ADMIN | CHECKIN_STAFF
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orders              Order[]
  tickets             Ticket[]
  checkIns            CheckIn[]
  sessions            Session[]
  auditLogs           AuditLog[]
  // Event organizer (events this user owns)
  organizedEvents     Event[]
  eventFaqAuthors     EventFAQ[]
  scheduleItemAuthors EventScheduleItem[]
  eventUpdateAuthors  EventUpdate[]

  @@index([role])
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

// ───────────────────────────────────────────────
// EVENT
// ───────────────────────────────────────────────

model Event {
  id                 String    @id @default(uuid())
  title              String
  slug               String    @unique
  shortDescription   String?
  description        String?
  posterObjectKey    String?
  status             String    @default("DRAFT") // DRAFT | PUBLISHED | COMPLETED | CANCELLED
  startAt            DateTime
  endAt              DateTime?
  venueName          String
  venueAddress       String?
  mapUrl             String?
  timezone           String    @default("Asia/Kolkata")
  totalCapacity      Int       @default(0)
  salesStartAt       DateTime?
  salesEndAt         DateTime?
  salesPaused        Boolean   @default(false)
  bookingClosed      Boolean   @default(false)
  contactEmail       String?
  contactPhone       String?
  terms              String?
  ticketNumberPrefix String    @default("") // e.g. "7N-2026-HYD-"
  organizerId        String // Who owns/created this event
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organizer     User                @relation(fields: [organizerId], references: [id])
  ticketTypes   TicketType[]
  orders        Order[]
  tickets       Ticket[]
  checkIns      CheckIn[]
  branding      EventBranding?
  partners      EventPartner[]
  templates     TicketTemplate[]
  auditLogs     AuditLog[]
  // Content modules
  faqs          EventFAQ[]
  performers    EventPerformer[]
  scheduleItems EventScheduleItem[]
  updates       EventUpdate[]

  @@index([slug])
  @@index([status])
  @@index([startAt])
  @@index([organizerId])
}

model EventBranding {
  id                     String   @id @default(uuid())
  eventId                String   @unique
  venueLogoObjectKey     String?
  primaryLogoObjectKey   String?
  footerArtworkObjectKey String?
  contentPartnerHeading  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id])
}

model EventPartner {
  id            String  @id @default(uuid())
  eventId       String
  name          String
  logoObjectKey String?
  displayOrder  Int     @default(0)
  partnerType   String  @default("CONTENT_PARTNER") // CONTENT_PARTNER | SPONSOR | VENUE

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId, displayOrder])
}

// ───────────────────────────────────────────────
// EVENT CONTENT MODULES (restored for platform features)
// ───────────────────────────────────────────────

model EventFAQ {
  id          String   @id @default(uuid())
  eventId     String
  authorId    String?
  question    String
  answer      String
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event  Event @relation(fields: [eventId], references: [id])
  author User? @relation(fields: [authorId], references: [id])

  @@index([eventId, sortOrder])
  @@index([eventId, isPublished])
}

model EventPerformer {
  id          String   @id @default(uuid())
  eventId     String
  name        String
  bio         String?
  imageUrl    String?
  instrument  String?
  role        String   @default("PERFORMER")
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId, sortOrder])
  @@index([eventId, isPublished])
}

model EventScheduleItem {
  id          String   @id @default(uuid())
  eventId     String
  authorId    String?
  title       String
  description String?
  startTime   String
  endTime     String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event  Event @relation(fields: [eventId], references: [id])
  author User? @relation(fields: [authorId], references: [id])

  @@index([eventId, sortOrder])
}

model EventUpdate {
  id          String   @id @default(uuid())
  eventId     String
  authorId    String?
  message     String
  updateType  String   @default("INSTRUCTION")
  visibility  String   @default("PUBLIC") // PUBLIC | ATTENDEES_ONLY
  isPinned    Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event  Event @relation(fields: [eventId], references: [id])
  author User? @relation(fields: [authorId], references: [id])

  @@index([eventId, publishedAt])
  @@index([eventId, updateType])
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([isRead])
}

// ───────────────────────────────────────────────
// TICKET TYPES
// ───────────────────────────────────────────────

model TicketType {
  id          String    @id @default(uuid())
  eventId     String
  name        String
  description String?
  price       Int       @default(0) // in cents (0 = free)
  currency    String    @default("INR")
  capacity    Int       @default(0)
  soldCount   Int       @default(0)
  maxPerOrder Int       @default(10)
  saleStartAt DateTime?
  saleEndAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  event     Event           @relation(fields: [eventId], references: [id])
  attendees OrderAttendee[]
  tickets   Ticket[]

  @@index([eventId])
  @@index([eventId, active])
}

// ───────────────────────────────────────────────
// ORDER
// ───────────────────────────────────────────────

model Order {
  id               String    @id @default(uuid())
  orderNumber      String    @unique
  eventId          String
  userId           String
  status           String    @default("PENDING_PAYMENT") // PENDING_PAYMENT | CONFIRMED | FAILED | EXPIRED | CANCELLED
  subtotal         Int       @default(0)
  fees             Int       @default(0)
  total            Int       @default(0)
  currency         String    @default("INR")
  paymentProvider  String? // stripe | utr | test
  paymentReference String?
  expiresAt        DateTime?
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  event     Event           @relation(fields: [eventId], references: [id])
  user      User            @relation(fields: [userId], references: [id])
  attendees OrderAttendee[]
  tickets   Ticket[]
  payments  Payment[]

  @@index([orderNumber])
  @@index([eventId])
  @@index([userId])
  @@index([status])
}

model OrderAttendee {
  id            String   @id @default(uuid())
  orderId       String
  ticketTypeId  String
  attendeeName  String
  attendeeEmail String?
  attendeePhone String?
  createdAt     DateTime @default(now())

  order      Order      @relation(fields: [orderId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  ticket     Ticket? // null until ticket generated after payment

  @@index([orderId])
  @@index([attendeeEmail])
}

// ───────────────────────────────────────────────
// PAYMENT
// ───────────────────────────────────────────────

model Payment {
  id                String    @id @default(uuid())
  orderId           String
  amount            Int
  currency          String    @default("INR")
  method            String // stripe | utr | test | free
  status            String    @default("PENDING") // PENDING | SUCCEEDED | FAILED | REFUNDED
  utrNumber         String?   @unique // 12-digit UPI UTR/Ref number
  providerPaymentId String?
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([utrNumber])
}

// ───────────────────────────────────────────────
// TICKET
// ───────────────────────────────────────────────

model Ticket {
  id              String    @id @default(uuid())
  ticketNumber    String    @unique
  eventId         String
  userId          String
  orderId         String?
  orderAttendeeId String?   @unique
  ticketTypeId    String
  status          String    @default("CONFIRMED") // CONFIRMED | CHECKED_IN | CANCELLED | EXPIRED
  qrTokenHash     String?   @unique
  templateVersion Int       @default(1)
  pngObjectKey    String?
  pdfObjectKey    String?
  renderingStatus String    @default("PENDING") // PENDING | COMPLETED | FAILED
  checkedInAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  event      Event          @relation(fields: [eventId], references: [id])
  user       User           @relation(fields: [userId], references: [id])
  order      Order?         @relation(fields: [orderId], references: [id])
  attendee   OrderAttendee? @relation(fields: [orderAttendeeId], references: [id])
  ticketType TicketType     @relation(fields: [ticketTypeId], references: [id])
  checkIn    CheckIn?

  @@index([ticketNumber])
  @@index([eventId])
  @@index([userId])
  @@index([orderId])
  @@index([status])
}

// ───────────────────────────────────────────────
// TICKET TEMPLATE
// ───────────────────────────────────────────────

model TicketTemplate {
  id              String    @id @default(uuid())
  eventId         String
  version         Int       @default(1)
  sourceObjectKey String
  width           Int
  height          Int
  outputFormat    String    @default("PNG")
  active          Boolean   @default(false)
  lockedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  event  Event                 @relation(fields: [eventId], references: [id])
  fields TicketTemplateField[]

  @@unique([eventId, version])
  @@index([eventId, active])
}

model TicketTemplateField {
  id              String  @id @default(uuid())
  templateId      String
  fieldName       String // EVENT_NAME | EVENT_DATE | EVENT_TIME | VENUE_NAME | VENUE_ADDRESS | ATTENDEE_NAME | TICKET_TYPE | QUANTITY | TICKET_NUMBER | ORDER_NUMBER | QR_CODE | BARCODE
  x               Int
  y               Int
  width           Int
  height          Int
  fontFamily      String  @default("Inter")
  fontSize        Int     @default(24)
  minimumFontSize Int     @default(10)
  fontWeight      String  @default("normal")
  alignment       String  @default("left")
  textTransform   String  @default("none")
  color           String  @default("#000000")
  visible         Boolean @default(true)

  template TicketTemplate @relation(fields: [templateId], references: [id])

  @@index([templateId])
}

// ───────────────────────────────────────────────
// CHECK-IN
// ───────────────────────────────────────────────

model CheckIn {
  id          String   @id @default(uuid())
  ticketId    String   @unique
  eventId     String
  scannerId   String
  checkedInAt DateTime @default(now())
  deviceInfo  String?
  result      String   @default("VALID") // VALID | ALREADY_CHECKED_IN | INVALID | WRONG_EVENT | PAYMENT_NOT_CONFIRMED

  ticket  Ticket @relation(fields: [ticketId], references: [id])
  event   Event  @relation(fields: [eventId], references: [id])
  scanner User   @relation(fields: [scannerId], references: [id])

  @@index([eventId])
  @@index([ticketId])
}

// ───────────────────────────────────────────────
// AUDIT LOG
// ───────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  eventId    String?
  action     String
  entityType String
  entityId   String
  ipAddress  String?
  userAgent  String?
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())

  actor User?  @relation(fields: [actorId], references: [id])
  event Event? @relation(fields: [eventId], references: [id])

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

// ───────────────────────────────────────────────
// PAYMENT WEBHOOK IDEMPOTENCY
// ───────────────────────────────────────────────

model PaymentWebhookEvent {
  id               String    @id @default(uuid())
  provider         String // stripe | utr | test
  externalEventId  String // Provider's unique event ID
  payloadHash      String?
  processingStatus String    @default("PENDING") // PENDING | PROCESSED | FAILED
  processedAt      DateTime?
  createdAt        DateTime  @default(now())

  @@unique([provider, externalEventId])
  @@index([processingStatus])
}
