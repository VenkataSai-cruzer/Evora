# ═══════════════════════════════════════════════════════════════
# 7 NOTES — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env in the project root for local development.
# For Render deployment, set these via Render Dashboard or render.yaml.
#
# ── Development Quick Start ──────────────────────────────────
# 1. DATABASE_URL: Leave as SQLite default for local dev
# 2. SESSION_SECRET: Generate a random string
# 3. Everything else with defaults will work for basic features
# ═══════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────────
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# Local development: SQLite (default)
DATABASE_URL="file:./dev.db"
DIRECT_URL="file:./dev.db"
# Production (Supabase PostgreSQL):
# DATABASE_URL="postgresql://postgres:PASSWORD@db.REF.supabase.co:5432/postgres?sslmode=require"
# DIRECT_URL="postgresql://postgres:PASSWORD@db.REF.supabase.co:5432/postgres?sslmode=require"

# ── URL Configuration ────────────────────────────────────────
APP_URL="http://localhost:3000"
API_URL="http://localhost:10000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:10000/api/v1"

# ── Session & Security ───────────────────────────────────────
SESSION_SECRET="generate-a-random-secret-key-here-at-least-32-chars"
CSRF_SECRET="another-random-secret-key-here-at-least-32-chars"
QR_SECRET="yet-another-random-secret-for-qr-token-encryption"

# ── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-for-nextauth"
# Google OAuth (optional):
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Cloudflare R2 (S3-compatible) ────────────────────────────
# Account ID: Cloudflare Dashboard > R2 > Bucket > Account ID
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="seven-notes-development"
# Endpoint format: https://{ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ENDPOINT=""

# ── Resend (Email) ────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="7 NOTES <tickets@7notes.in>"

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL="info"

# ── Seed Safety (Production) ────────────────────────────────
# WARNING: Only set this to true if you explicitly want to seed a production DB.
# Misuse will overwrite or duplicate user data.
# ALLOW_PRODUCTION_SEED=false

# ── Application Version ──────────────────────────────────────
NEXT_PUBLIC_APP_VERSION="0.1.0"
